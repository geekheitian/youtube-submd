<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- 唯一标识符 -->
    <key>Label</key>
    <string>com.yangkai.bestpartners</string>

    <!-- 执行命令：用绝对路径的 Python 运行调度脚本 -->
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3</string>
        <string>/Users/yangkai/projects/youtube-submd/scheduler.py</string>
    </array>

    <!-- 工作目录 -->
    <key>WorkingDirectory</key>
    <string>/Users/yangkai/projects/youtube-submd</string>

    <!-- 登录后立即启动 -->
    <key>RunAtLoad</key>
    <true/>

    <!-- 崩溃后自动重启 -->
    <key>KeepAlive</key>
    <true/>

    <!-- 标准输出日志 -->
    <key>StandardOutPath</key>
    <string>/Users/yangkai/projects/youtube-submd/scheduler.log</string>

    <!-- 错误输出日志（合并到同一文件） -->
    <key>StandardErrorPath</key>
    <string>/Users/yangkai/projects/youtube-submd/scheduler.log</string>

    <!-- 环境变量：确保能找到 homebrew 工具和读取 API Key -->
    <!-- API Key 请通过项目目录下的 .env 文件配置，不要写在这里 -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/yangkai</string>
    </dict>

    <!-- 限速：最小重启间隔（秒），防止崩溃循环 -->
    <key>ThrottleInterval</key>
    <integer>60</integer>
</dict>
</plist>
